# GristMill — environment variable reference
# Copy this file to .env and fill in your secrets.
# Never commit .env to version control.

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Slack integration ─────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Ollama (local LLM — used with --profile ollama) ──────────────────────────
# Defaults to the ollama container when running via docker compose.
# Override to point at a local host install: http://host.docker.internal:11434
OLLAMA_HOST=http://ollama:11434
OLLAMA_PORT=11434

# ── MLflow (experiment tracking — used with --profile mlflow) ────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_PORT=5000

# ── Dashboard / server ────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Build metadata (set automatically by CI) ─────────────────────────────────
BUILD_DATE=
GIT_SHA=dev

# ── Optional: override config file path ──────────────────────────────────────
# If set, this file is bind-mounted into the container at /data/gristmill/config.yaml
# GRISTMILL_CONFIG_PATH=/path/to/your/config.yaml
