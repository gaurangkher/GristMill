# GristMill — environment variable reference
# Copy this file to .env and fill in your secrets.
# Never commit .env to version control.

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Slack integration ─────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Ollama (local LLM — used with --profile ollama) ──────────────────────────
# Set GRISTMILL_HAMMER_OLLAMA_ENABLED=true when running --profile ollama or full.
# Without this, GristMill skips Ollama entirely and goes straight to Anthropic.
# Override GRISTMILL_HAMMER_OLLAMA_BASE_URL to point at a host install.
GRISTMILL_HAMMER_OLLAMA_ENABLED=true
GRISTMILL_HAMMER_OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434

# ── MLflow (experiment tracking — used with --profile mlflow) ────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_PORT=5000

# ── Dashboard / server ────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Build metadata (set automatically by CI) ─────────────────────────────────
BUILD_DATE=
GIT_SHA=dev

# ── Optional: override config file path ──────────────────────────────────────
# If set, this file is bind-mounted into the container at /data/gristmill/config.yaml
# GRISTMILL_CONFIG_PATH=/path/to/your/config.yaml
