{
  "name": "gristmill-integrations",
  "version": "0.1.0",
  "description": "GristMill TypeScript shell — HTTP adapters, Bell Tower notifications, and dashboard",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
