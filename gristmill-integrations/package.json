    "nodemailer": "^6.9.13",
    "ulid": "^2.3.0",
    "ws": "^8.17.1",
    "yaml": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^6.4.15",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "optionalDependencies": {
    "@gristmill/core": "file:../gristmill-core/crates/grist-ffi"
