<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.gristmill.trainer</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/gristmill-trainer</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/tmp/com.gristmill.trainer.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/com.gristmill.trainer.stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>

    <!-- Install into ~/Library/LaunchAgents/ for per-user, or
         /Library/LaunchDaemons/ for system-wide (requires root). -->
</dict>
</plist>
